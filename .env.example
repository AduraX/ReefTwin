# =============================================================================
# ReefTwin Environment Configuration
# Copy to .env and fill in values: cp .env.example .env
# =============================================================================

# --- LLM Provider ---
REEFTWIN_LLM_PROVIDER=mock              # claude | openai | qwen | qwen-local | ollama | mock
REEFTWIN_LLM_MODEL=claude-sonnet-4-20250514
REEFTWIN_LLM_TEMPERATURE=0.3
REEFTWIN_LLM_MAX_TOKENS=1024

# Claude (Anthropic)
ANTHROPIC_API_KEY=

# OpenAI / Codex
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Qwen (DashScope)
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Ollama (local — requires ollama installed and running)
OLLAMA_BASE_URL=http://localhost:11434

# Qwen Local (HuggingFace transformers — no API/Ollama needed)
# REEFTWIN_LLM_PROVIDER=qwen-local
# REEFTWIN_LLM_MODEL=Qwen/Qwen3-0.6B      # 0.6B: ~1.2GB, runs on any CPU
# REEFTWIN_LLM_MODEL=Qwen/Qwen3-1.7B      # 1.7B: ~3.4GB
# REEFTWIN_LLM_MODEL=Qwen/Qwen3-4B        # 4B: ~8GB
# REEFTWIN_LLM_MODEL=Qwen/Qwen3-8B        # 8B: ~16GB, needs GPU or 32GB RAM

# --- Vector Store ---
REEFTWIN_VECTOR_STORE_BACKEND=memory    # memory | qdrant | pgvector | milvus

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=
QDRANT_COLLECTION=reef_knowledge
QDRANT_PREFER_GRPC=false

# pgvector
PGVECTOR_DSN=postgresql://localhost:5432/reeftwin
PGVECTOR_TABLE=reef_embeddings
PGVECTOR_INDEX_TYPE=hnsw                # hnsw | ivfflat
PGVECTOR_HNSW_M=16
PGVECTOR_HNSW_EF=64
PGVECTOR_PROBES=10

# Milvus
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION=reef_knowledge
MILVUS_INDEX_TYPE=IVF_FLAT              # IVF_FLAT | HNSW | IVF_SQ8
MILVUS_NLIST=128
MILVUS_NPROBE=16
MILVUS_METRIC_TYPE=COSINE               # COSINE | L2 | IP

# --- State Store ---
REEFTWIN_STATE_STORE_BACKEND=json       # json | s3

# --- S3-Compatible Storage (SeaweedFS / MinIO / AWS S3) ---
REEFTWIN_S3_ENDPOINT=                   # e.g. http://seaweedfs-s3:8333 (leave empty for AWS)
REEFTWIN_S3_BUCKET=reeftwin
REEFTWIN_S3_ACCESS_KEY=
REEFTWIN_S3_SECRET_KEY=
REEFTWIN_S3_REGION=us-east-1
REEFTWIN_S3_USE_SSL=false

# --- Forecasting ---
REEFTWIN_FORECAST_BACKEND=holtwinters   # holtwinters | sarima | prophet

# --- Paths (defaults work for local dev) ---
# REEFTWIN_STATE_PATH=data/gold/reef_state.json
# REEFTWIN_MODEL_PATH=models/bleaching_risk/model.joblib
# REEFTWIN_FEATURES_PATH=data/gold/reef_features.csv

# --- Logging ---
REEFTWIN_LOG_LEVEL=INFO
